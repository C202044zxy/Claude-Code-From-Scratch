# Copy to .env and fill in. Only the key for the chosen provider is required.

# Provider: "anthropic" (default) or "deepseek".
# DeepSeek ships an Anthropic-compatible endpoint, so the same SDK/loop works
# for both — handy for early dev without an Anthropic key.
CC_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...

# Optional overrides. Left unset, each provider picks its own default:
#   anthropic -> claude-opus-4-8, 16000 tokens
#   deepseek  -> deepseek-v4-flash, 16000 tokens
# CC_MODEL=claude-opus-4-8
# CC_MAX_TOKENS=16000
CC_EFFORT=high   # Anthropic only; ignored by deepseek
